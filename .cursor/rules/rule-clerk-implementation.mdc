-- Função para extrair user_id do JWT do Clerk
CREATE OR REPLACE FUNCTION get_clerk_user_id()
RETURNS text AS $$
BEGIN
  RETURN (SELECT auth.jwt()->>'sub');
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Políticas RLS adaptadas para Clerk
-- Exemplo para uma tabela "contacts"
CREATE POLICY "Users can view their own contacts"
ON "public"."contacts"
FOR SELECT
TO authenticated
USING (
  (get_clerk_user_id() = user_id) -- Assumindo que a tabela tem uma coluna 'user_id'
);

CREATE POLICY "Users can insert their own contacts"
ON "public"."contacts"
FOR INSERT
TO authenticated
WITH CHECK (
  (get_clerk_user_id() = user_id)
);
"""
