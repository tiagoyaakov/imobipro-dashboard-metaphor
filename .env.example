# =================================================================
# 🏢 ImobiPRO Dashboard - Configurações de Ambiente
# =================================================================
# Este arquivo contém todas as variáveis de ambiente necessárias
# para executar o projeto em desenvolvimento e produção.
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Substitua os valores de exemplo pelos reais
# 3. Nunca commite o arquivo .env no Git
# =================================================================

# -----------------------------------------------------------------
# 🛠️ AMBIENTE DE DESENVOLVIMENTO
# -----------------------------------------------------------------
# Define o ambiente de execução da aplicação
NODE_ENV=development

# -----------------------------------------------------------------
# 🔐 CLERK AUTHENTICATION
# -----------------------------------------------------------------
# Chave pública do Clerk para autenticação
# Encontre em: Clerk Dashboard > API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Chave secreta do Clerk (apenas para webhooks futuros)
# CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# -----------------------------------------------------------------
# 🚀 VERCEL ENVIRONMENT VARIABLES (Auto-geradas em produção)
# -----------------------------------------------------------------
# Estas variáveis são automaticamente definidas pela Vercel
# Não é necessário configurá-las manualmente em produção

# Ambiente da Vercel (development, preview, production)
VITE_VERCEL_ENV=development

# URL do deployment
VITE_VERCEL_URL=localhost:8080

# URL de produção do projeto
VITE_VERCEL_PROJECT_PRODUCTION_URL=your-domain.com

# -----------------------------------------------------------------
# 🔧 CONFIGURAÇÕES DE DESENVOLVIMENTO
# -----------------------------------------------------------------
# Porta do servidor de desenvolvimento
VITE_DEV_PORT=8083

# Habilitar logs de debug no console
VITE_DEBUG_MODE=false

# Habilitar mock de dados em desenvolvimento
VITE_USE_MOCK_DATA=true

# -----------------------------------------------------------------
# 🎨 CONFIGURAÇÕES DE TEMA (Opcionais)
# -----------------------------------------------------------------
# Tema padrão da aplicação (light, dark, system)
VITE_DEFAULT_THEME=dark

# Cor primária customizada (HSL format)
VITE_PRIMARY_COLOR=220 91% 51%

# -----------------------------------------------------------------
# 📊 ANALYTICS & MONITORING (Opcionais)
# -----------------------------------------------------------------
# Google Analytics 4 Measurement ID
# Formato: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry DSN para monitoramento de erros
# Encontre em: Sentry Dashboard > Settings > Client Keys (DSN)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# -----------------------------------------------------------------
# 🔑 API KEYS EXTERNAS (Opcionais)
# -----------------------------------------------------------------
# Chave API para serviços de geolocalização
VITE_GEOCODING_API_KEY=your-geocoding-api-key

# Chave API para integração com WhatsApp Business
VITE_WHATSAPP_API_KEY=your-whatsapp-api-key

# -----------------------------------------------------------------
# 📧 CONFIGURAÇÕES DE EMAIL (Para funcionalidades futuras)
# -----------------------------------------------------------------
# Configurações SMTP para envio de emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# -----------------------------------------------------------------
# 🤖 IA E AUTOMAÇÃO (Para funcionalidades futuras)
# -----------------------------------------------------------------
# OpenAI API Key para funcionalidades de IA
OPENAI_API_KEY=sk-your-openai-api-key

# -----------------------------------------------------------------
# 🔒 SEGURANÇA
# -----------------------------------------------------------------
# Chave secreta para JWT (apenas backend, se implementado)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Chave de criptografia para dados sensíveis
ENCRYPTION_KEY=your-encryption-key-32-chars

# -----------------------------------------------------------------
# 💾 CACHE E PERFORMANCE
# -----------------------------------------------------------------
# TTL do cache em segundos (padrão: 5 minutos)
VITE_CACHE_TTL=300

# Habilitar Service Worker para cache offline
VITE_ENABLE_SW=true

# -----------------------------------------------------------------
# 🌍 LOCALIZAÇÃO E INTERNACIONALIZAÇÃO
# -----------------------------------------------------------------
# Idioma padrão da aplicação
VITE_DEFAULT_LOCALE=pt-BR

# Fuso horário padrão
VITE_DEFAULT_TIMEZONE=America/Sao_Paulo

# -----------------------------------------------------------------
# 📱 PWA CONFIGURATION
# -----------------------------------------------------------------
# Nome da aplicação PWA
VITE_APP_NAME=ImobiPRO Dashboard

# Descrição da aplicação
VITE_APP_DESCRIPTION=Sistema de gestão imobiliária profissional

# URL base da aplicação
VITE_APP_BASE_URL=https://your-domain.com
